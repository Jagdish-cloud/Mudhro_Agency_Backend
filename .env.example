PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/MudhroAgency
BCRYPT_SALT_ROUNDS=10
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Public URL the frontend is served from (used in emails + portal links).
APP_PUBLIC_URL=http://localhost:5173

# Background scheduler for invoice reminders / overdue recompute.
# Leave false for local dev unless you explicitly want timed sends.
ENABLE_SCHEDULER=false

# Secret for Azure Timer Functions calling POST /api/internal/jobs/reminder-tick.
# Must match the x-scheduler-secret header. Min 32 characters.
SCHEDULER_SECRET=

# File uploads (attachments, org logos). Relative to process cwd or absolute.
UPLOAD_DIR=uploads

# Invoice numbering. Final format: {PREFIX}-{YEAR}-{seq.padStart(PAD, '0')}.
INVOICE_NUMBER_PREFIX=INV
INVOICE_NUMBER_PAD=5

# SMTP (optional). If SMTP_HOST is empty, mail sending is stubbed for dev.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true,
#   SMTP_USER=you@gmail.com, SMTP_PASS=<app-password>
# Mailgun example: SMTP_HOST=smtp.mailgun.org, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=invoices@example.com
SMTP_FROM_NAME=Mudhro
