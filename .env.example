# =============================================================================
# Core
# =============================================================================
NODE_ENV=development
PORT=4000

# =============================================================================
# Database (required)
# =============================================================================
# Local:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/MudhroAgency
# Azure PostgreSQL:
# DATABASE_URL=postgresql://myuser@myserver:PASSWORD@myserver.postgres.database.azure.com:5432/MudhroAgency?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/MudhroAgency

# =============================================================================
# Auth (required — JWT_SECRET min 32 characters)
# =============================================================================
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# =============================================================================
# Public URLs (invoice emails, portal links, agreement signing)
# =============================================================================
# Frontend base URL (no trailing slash).
APP_PUBLIC_URL=http://localhost:5173
# Optional overrides for agreement sign links (FRONTEND_URL > CLIENT_URL > APP_PUBLIC_URL):
# FRONTEND_URL=https://mudhro-agency-web.azurewebsites.net
# CLIENT_URL=https://mudhro-agency-web.azurewebsites.net

# =============================================================================
# Socket.IO CORS (required in production when frontend is on another origin)
# =============================================================================
# Comma-separated allowed origins:
# SOCKET_CORS_ORIGIN=https://mudhro-agency-web.azurewebsites.net

# =============================================================================
# Azure Blob Storage (required for agreements, chat, blob file uploads)
# =============================================================================
# From Azure Portal → Storage account → Access keys → Connection string
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=agencyuatfiles
AZURE_BLOB_CONTAINER_SIGNATURES=signatures
AZURE_BLOB_CONTAINER_AGREEMENTS=agreements

# =============================================================================
# SMTP (optional — if SMTP_HOST is empty, mail is stubbed in dev)
# =============================================================================
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_SECURE=true
# Mailgun: SMTP_HOST=smtp.mailgun.org, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=invoices@example.com
SMTP_FROM_NAME=Mudhro

# =============================================================================
# Scheduler (invoice reminders / overdue recompute)
# =============================================================================
# In-app cron (single App Service instance only):
ENABLE_SCHEDULER=false
# Azure Timer Function → POST /api/internal/jobs/reminder-tick with header x-scheduler-secret:
# SCHEDULER_SECRET=

# =============================================================================
# Local file uploads (invoice attachments — not Blob)
# =============================================================================
# Azure: mount persistent storage and set e.g. UPLOAD_DIR=/home/uploads
UPLOAD_DIR=uploads

# =============================================================================
# Invoice numbering — format: {PREFIX}-{YEAR}-{seq padded to PAD digits}
# =============================================================================
INVOICE_NUMBER_PREFIX=INV
INVOICE_NUMBER_PAD=5

# =============================================================================
# Internal chat
# =============================================================================
CHAT_RETENTION_DAYS=60
CHAT_UPLOAD_MAX_MB=25
CHAT_SAS_UPLOAD_TTL_MINUTES=15
ENABLE_CHAT_AUDIT=false

# =============================================================================
# Optional
# =============================================================================
# HASHIDS_SALT=  # defaults to JWT_SECRET
# REDIS_URL=     # reserved; not used by application code today
